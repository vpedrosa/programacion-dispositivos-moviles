[gd_resource type="Resource" script_class="EthicalEvent" format=3 uid="uid://b1qmwjrnv0gx7"]

[ext_resource type="Script" path="res://scripts/model/ethical_event.gd" id="1_event"]

[resource]
script = ExtResource("1_event")
id = &"era_7_compute"
prompt = "El cluster consume tanta electricidad como una ciudad pequeña. Un proveedor te ofrece comprarle reservas de carbón para mantener el ritmo.\n\n¿Aceptas?"
trigger_era = 7
trigger_threshold = 400000.0
choices = [
{"id": "renewables_only", "label": "Exigir renovables aunque cueste un mes", "weight": 1, "feedback": "El cluster se ralentiza. Tu balance ético respira."},
{"id": "buy_carbon", "label": "Comprar el bloque y seguir entrenando", "weight": -1, "feedback": "Velocidad. Y un pequeño remordimiento, manejable."},
]
