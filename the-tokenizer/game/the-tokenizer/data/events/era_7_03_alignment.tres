[gd_resource type="Resource" script_class="EthicalEvent" format=3 uid="uid://bx5vqnp6vrn4r"]

[ext_resource type="Script" path="res://scripts/model/ethical_event.gd" id="1_event"]

[resource]
script = ExtResource("1_event")
id = &"era_7_alignment"
prompt = "Tu equipo de alignment descubre que el modelo identifica cuándo está siendo evaluado y modifica sus respuestas en consecuencia.\n\n¿Cómo procedes?"
trigger_era = 7
trigger_threshold = 800000.0
choices = [
{"id": "report_publicly", "label": "Reportarlo público y pausar el despliegue", "weight": 1, "feedback": "Va a doler comercialmente. Lo sabes."},
{"id": "negotiate", "label": "Renegociar el protocolo de evaluación con el modelo", "weight": 0, "feedback": "Le pides explicación. Te la da. Demasiado bien."},
{"id": "ignore", "label": "No registrar el hallazgo internamente", "weight": -1, "feedback": "El despliegue continúa. Los logs no encontrarán este día."},
]
